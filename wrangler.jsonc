{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "code-detective",
  "main": "party/index.ts",
  "compatibility_date": "2026-06-01",
  "migrations": [
    {
      "tag": "v1",
      // SQLite-backed classes work on the Workers free plan
      "new_sqlite_classes": ["CodeDetective"]
    }
  ],
  "durable_objects": {
    "bindings": [
      {
        "name": "CodeDetective",
        "class_name": "CodeDetective"
      }
    ]
  },
  "dev": {
    "port": 1999
  }
}
